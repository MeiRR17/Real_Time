# =============================================================================
# Telephony Load Monitoring System - Environment Configuration
# =============================================================================
# This file contains all environment variables for the telephony monitoring
# system with separate databases for each component. Copy this to .env and 
# customize for your environment.
# =============================================================================

# =============================================================================
# Multi-Database Configuration
# =============================================================================
# Each component has its own database for better performance and scalability

# CUCM Database Configuration
CUCM_PRIMARY_URL=postgresql://postgres:password@cucm-postgres:5432/cucm_db
CUCM_REPLICA_URLS=
CUCM_DB_POOL_SIZE=5

# UCCX Database Configuration
UCCX_PRIMARY_URL=postgresql://postgres:password@uccx-postgres:5432/uccx_db
UCCX_REPLICA_URLS=
UCCX_DB_POOL_SIZE=5

# CMS Database Configuration
CMS_PRIMARY_URL=postgresql://postgres:password@cms-postgres:5432/cms_db
CMS_REPLICA_URLS=
CMS_DB_POOL_SIZE=5

# IMP Database Configuration
IMP_PRIMARY_URL=postgresql://postgres:password@imp-postgres:5432/imp_db
IMP_REPLICA_URLS=
IMP_DB_POOL_SIZE=5

# Meeting Place Database Configuration
MEETING_PLACE_PRIMARY_URL=postgresql://postgres:password@meeting-place-postgres:5432/meeting_place_db
MEETING_PLACE_REPLICA_URLS=
MEETING_PLACE_DB_POOL_SIZE=5

# TGW Database Configuration
TGW_PRIMARY_URL=postgresql://postgres:password@tgw-postgres:5432/tgw_db
TGW_REPLICA_URLS=
TGW_DB_POOL_SIZE=5

# SBC Database Configuration
SBC_PRIMARY_URL=postgresql://postgres:password@sbc-postgres:5432/sbc_db
SBC_REPLICA_URLS=
SBC_DB_POOL_SIZE=5

# Expressway Database Configuration
EXPRESSWAY_PRIMARY_URL=postgresql://postgres:password@expressway-postgres:5432/expressway_db
EXPRESSWAY_REPLICA_URLS=
EXPRESSWAY_DB_POOL_SIZE=5

# Superset Database Configuration
SUPERSET_PRIMARY_URL=postgresql://postgres:password@superset-postgres:5432/superset_db
SUPERSET_REPLICA_URLS=
SUPERSET_DB_POOL_SIZE=10

# =============================================================================
# Legacy Database Configuration (for backward compatibility)
# =============================================================================
# PostgreSQL connection string for the main database (deprecated)
DATABASE_URL=postgresql://postgres:password@postgres:5432/telephony_db

# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# Scheduler Configuration
# =============================================================================
# APScheduler settings
SCHEDULER_TIMEZONE=UTC
SCHEDULER_ENABLED=true
SCHEDULER_JOB_DEFAULTS_COALESCE=true
SCHEDULER_JOB_DEFAULTS_MAX_INSTANCES=1

# Collection interval in seconds (default: 300 = 5 minutes)
COLLECTION_INTERVAL=300

# =============================================================================
# Mock Server Configuration
# =============================================================================
# Mock server settings
MOCK_SERVER_ENABLED=true
MOCK_SERVER_HOST=0.0.0.0
MOCK_SERVER_PORT=8001

# Mock data generation settings
MOCK_DATA_FLUCTUATION=true
MOCK_DATA_SEED=12345
MOCK_DATA_BUSINESS_HOURS_ONLY=false

# =============================================================================
# API Configuration
# =============================================================================
# API server settings
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RELOAD=false

# CORS settings
API_CORS_ORIGINS='["*"]'
API_CORS_CREDENTIALS=true

# AXLerate REST Middleware Configuration
AXLERATE_URL=http://axlerate:8000

# AXLerate Service Configuration
AXL_USER=admin
AXL_PASSWORD=password
AXL_PORT=8443
AXL_VERIFY_SSL=false
PERFMON_TIMEOUT=30
PERFMON_RETRIES=3

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# Cisco Server Configuration (for future real API integration)
# =============================================================================
# Multi-Node Configuration Examples:
# 
# Single node (default):
# CUCM_NODES=192.168.1.100
#
# Multiple nodes (cluster):
# CUCM_NODES=10.0.0.1,10.0.0.2,10.0.0.3
#
# Mixed configuration:
# CUCM_NODES=192.168.1.100,192.168.1.101,10.0.0.50
#
# Each node will be identified as CUCM-Node-1, CUCM-Node-2, etc. in the database
# and can be distinguished in Superset dashboards.

# CUCM (Cisco Unified Communications Manager)
# Multiple nodes can be specified as comma-separated IP addresses
CUCM_NODES=192.168.1.100
CUCM_USERNAME=admin
CUCM_PASSWORD=password
CUCM_PORT=8443
CUCM_VERIFY_SSL=false

# UCCX (Unified Contact Center Express)
# Multiple nodes can be specified as comma-separated IP addresses
UCCX_NODES=192.168.1.101
UCCX_USERNAME=admin
UCCX_PASSWORD=password
UCCX_PORT=8445
UCCX_VERIFY_SSL=false

# CMS (Cisco Meeting Server)
# Multiple nodes can be specified as comma-separated IP addresses
CMS_NODES=192.168.1.102
CMS_USERNAME=admin
CMS_PASSWORD=password
CMS_PORT=445
CMS_VERIFY_SSL=false

# IMP (Instant Messaging & Presence)
# Multiple nodes can be specified as comma-separated IP addresses
IMP_NODES=192.168.1.103
IMP_USERNAME=admin
IMP_PASSWORD=password
IMP_PORT=8222
IMP_VERIFY_SSL=false

# Meeting Place (Legacy)
# Multiple nodes can be specified as comma-separated IP addresses
MEETING_PLACE_NODES=192.168.1.104
MEETING_PLACE_USERNAME=admin
MEETING_PLACE_PASSWORD=password
MEETING_PLACE_PORT=8080
MEETING_PLACE_VERIFY_SSL=false

# TGW (Trunk Gateway)
# Multiple nodes can be specified as comma-separated IP addresses
TGW_NODES=localhost
TGW_USERNAME=
TGW_PASSWORD=
TGW_PORT=161
TGW_VERIFY_SSL=false
TGW_SNMP_COMMUNITY=public
TGW_SNMP_VERSION=2c
TGW_SNMP_TIMEOUT=5

# SBC (Session Border Controller)
# Multiple nodes can be specified as comma-separated IP addresses
SBC_NODES=localhost
SBC_USERNAME=
SBC_PASSWORD=
SBC_PORT=443
SBC_VERIFY_SSL=false
SBC_API_VERSION=v1

# Expressway
# Multiple nodes can be specified as comma-separated IP addresses
EXPRESSWAY_NODES=localhost
EXPRESSWAY_USERNAME=
EXPRESSWAY_PASSWORD=
EXPRESSWAY_PORT=443
EXPRESSWAY_VERIFY_SSL=false
EXPRESSWAY_API_VERSION=v1

# =============================================================================
# FEATURE TOGGLES - Real API Integration
# =============================================================================
USE_REAL_CUCM=false
USE_REAL_UCCX=false
USE_REAL_CMS=false
USE_REAL_IMP=false
USE_REAL_MEETING_PLACE=false
USE_REAL_TGW=false
USE_REAL_SBC=false
USE_REAL_EXPRESSWAY=false

# =============================================================================
# Performance Configuration
# =============================================================================
# Request timeouts in seconds
REQUEST_TIMEOUT=30
COLLECTION_TIMEOUT=60

# Retry settings
MAX_RETRIES=3
RETRY_DELAY=5

# =============================================================================
# Development Settings
# =============================================================================
# Enable/disable features for development
DEV_MODE=false
MOCK_EXTERNAL_APIS=true
SKIP_SSL_VERIFICATION=true
